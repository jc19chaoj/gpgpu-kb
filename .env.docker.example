# Copy this file to `.env` next to docker-compose.yml and fill in values.
#   cp .env.docker.example .env
#
# All KB_* vars are read by backend/kb/config.py. The plain ANTHROPIC_API_KEY /
# OPENAI_API_KEY / DEEPSEEK_API_KEY / GITHUB_TOKEN names are also accepted as a
# convenience.

# ─── Build-time switches ──────────────────────────────────────────────
# Backend "extras" installed inside the image. Default includes the ML stack
# (ChromaDB + sentence-transformers ≈ 2 GB). Set to "llm-cloud" or "" to slim down.
# Re-run `docker compose build backend` after changing.
BACKEND_INSTALL_EXTRAS=ml,llm-cloud

# Public URL the browser uses to reach the backend. BAKED into the frontend
# bundle at build time; rebuild after changing.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Host port mappings (containers always listen on 8000 / 3000 internally).
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ─── LLM provider ─────────────────────────────────────────────────────
# `hermes` (the default for local dev) requires the Hermes CLI on PATH and
# is NOT available inside the container. Pick a cloud provider here.
KB_LLM_PROVIDER=openai
# KB_LLM_PROVIDER=anthropic
# KB_LLM_PROVIDER=deepseek

# Pick the matching API key for the provider above.
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=

# Optional model overrides
# KB_OPENAI_MODEL=gpt-4o-mini
# KB_ANTHROPIC_MODEL=claude-sonnet-4-6
# KB_DEEPSEEK_MODEL=deepseek-chat
# KB_LLM_TIMEOUT_SECONDS=180

# Output language for summaries / reports: `en` or `zh`.
KB_LANGUAGE=en

# ─── Ingestion ────────────────────────────────────────────────────────
# Highly recommended; without a token GitHub Search API rate-limits to ~10/min.
GITHUB_TOKEN=

# KB_ARXIV_PER_CATEGORY=50
# KB_INGEST_EMPTY_DB_DAYS=30
# KB_INGEST_GAP_MIN_DAYS=1
# KB_INGEST_GAP_MAX_DAYS=30

# Quality gate: papers below this score (max of originality, impact) get
# is_processed=2 (hidden). Raise to be pickier, lower to surface more.
# KB_QUALITY_SCORE_THRESHOLD=7.0

# ─── Auth on /api/chat ────────────────────────────────────────────────
# When set, callers must send `Authorization: Bearer <token>`. Leave empty for
# frictionless local dev. STRONGLY RECOMMENDED if you expose the API publicly.
KB_CHAT_TOKEN=

# ─── CORS / API limits ────────────────────────────────────────────────
# docker-compose.yml sets a sane default. Override here if you serve the
# frontend from a different origin (e.g. behind cpolar / a real domain).
# KB_CORS_ORIGINS=["http://localhost:3000","https://kb.example.com"]
# KB_CHAT_QUERY_MAX_LEN=2000
# KB_CHAT_TOP_K_MAX=20
