# GPGPU Knowledge Base — environment configuration
# Copy this file to `.env` and fill in values you need.
# All KB_-prefixed values map to fields in kb.config.Settings.

# ─── App ──────────────────────────────────────────────
KB_LOG_LEVEL=INFO

# ─── CORS ─────────────────────────────────────────────
# JSON list (pydantic-settings parses list types as JSON)
KB_CORS_ORIGINS=["http://localhost:3000"]

# ─── Storage ──────────────────────────────────────────
KB_DATA_DIR=./data
KB_DATABASE_URL=sqlite:///./data/kb.sqlite

# ─── Embeddings ───────────────────────────────────────
KB_EMBEDDING_MODEL=all-MiniLM-L6-v2
KB_CHROMA_DIR=./data/chroma

# ─── LLM provider ─────────────────────────────────────
# One of: hermes (default, uses local `hermes` CLI), anthropic, openai, deepseek
KB_LLM_PROVIDER=hermes
KB_LLM_TIMEOUT_SECONDS=180

# Cloud LLM credentials (used when KB_LLM_PROVIDER=anthropic|openai|deepseek).
# These can also be set without the KB_ prefix using the standard names.
# ANTHROPIC_API_KEY=
KB_ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_API_KEY=
KB_OPENAI_MODEL=gpt-4o-mini
# DeepSeek uses the OpenAI-compatible API; accepted as KB_DEEPSEEK_API_KEY or DEEPSEEK_API_KEY.
# DEEPSEEK_API_KEY=
KB_DEEPSEEK_MODEL=deepseek-chat
KB_DEEPSEEK_BASE_URL=https://api.deepseek.com

# ─── Ingestion ────────────────────────────────────────
# GitHub Personal Access Token. Without it, the GitHub Search API is
# rate-limited to 10 req/min — too low for the daily pipeline.
# Accepted as KB_GITHUB_TOKEN or GITHUB_TOKEN.
# GITHUB_TOKEN=
KB_ARXIV_PER_CATEGORY=50

# ─── API limits ───────────────────────────────────────
KB_CHAT_QUERY_MAX_LEN=2000
KB_CHAT_TOP_K_MAX=20

# ─── Chat auth ────────────────────────────────────────
# Optional bearer token guarding POST /api/chat. If unset, the endpoint
# is open (good for local dev). If set, callers must send
# `Authorization: Bearer <token>` or get 401.
# KB_CHAT_TOKEN=replace-me-with-a-long-random-string
