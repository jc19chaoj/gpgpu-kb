# GPGPU Knowledge Base — environment configuration
# Copy this file to `.env` and fill in values you need.
# All KB_-prefixed values map to fields in kb.config.Settings.

# ─── App ──────────────────────────────────────────────
KB_LOG_LEVEL=INFO

# ─── CORS ─────────────────────────────────────────────
# JSON list (pydantic-settings parses list types as JSON)
KB_CORS_ORIGINS=["http://localhost:3000"]

# ─── Storage ──────────────────────────────────────────
KB_DATA_DIR=./data
KB_DATABASE_URL=sqlite:///./data/kb.sqlite

# ─── Embeddings ───────────────────────────────────────
KB_EMBEDDING_MODEL=all-MiniLM-L6-v2
KB_CHROMA_DIR=./data/chroma

# ─── LLM provider (fast role) ────────────────────────
# The *fast* role drives daily batch work: summarization, scoring, daily
# reports. Cheap + fast models win here because the pipeline burns
# hundreds of calls per run.
# One of: hermes (default, uses local `hermes` CLI), anthropic, openai, deepseek
KB_LLM_PROVIDER=hermes
KB_LLM_TIMEOUT_SECONDS=180

# Output language for LLM-generated content (summaries, scores, daily reports).
# One of: en (default), zh (简体中文). Override per-run with `python -m kb.daily --lang zh`.
# NOTE: does NOT affect /api/chat prompts — those are hardcoded Chinese.
KB_LANGUAGE=zh

# Cloud LLM credentials (used when KB_LLM_PROVIDER=anthropic|openai|deepseek).
# These can also be set without the KB_ prefix using the standard names.
# ANTHROPIC_API_KEY=
KB_ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_API_KEY=
KB_OPENAI_MODEL=gpt-4o-mini
# DeepSeek uses the OpenAI-compatible API; accepted as KB_DEEPSEEK_API_KEY or DEEPSEEK_API_KEY.
# DEEPSEEK_API_KEY=
KB_DEEPSEEK_MODEL=deepseek-chat
KB_DEEPSEEK_BASE_URL=https://api.deepseek.com

# ─── LLM provider (expert role, optional) ────────────
# The *expert* role drives interactive chat only — /api/chat and
# /api/chat/stream. Daily batch work (summarization, scoring, reports)
# stays on the fast role above.
#
# Both vars are optional. Unset fields fall back to the fast role:
#   - KB_LLM_EXPERT_PROVIDER unset → use KB_LLM_PROVIDER
#   - KB_LLM_EXPERT_MODEL    unset → use the expert provider's default model
#                                    (KB_ANTHROPIC_MODEL / KB_OPENAI_MODEL / KB_DEEPSEEK_MODEL)
#
# Typical setups:
#   1. Same provider, beefier model for chat (cheapest for most users):
#        KB_LLM_EXPERT_PROVIDER=deepseek
#        KB_LLM_EXPERT_MODEL=deepseek-reasoner
#   2. Cross-provider — cheap for batch, premium for chat. Requires BOTH
#      providers' API keys to be set above:
#        KB_LLM_PROVIDER=deepseek         (fast)
#        KB_LLM_EXPERT_PROVIDER=anthropic (expert)
#        KB_LLM_EXPERT_MODEL=claude-sonnet-4-6
#
# Note: hermes provider ignores KB_LLM_EXPERT_MODEL (CLI has no --model flag).
# KB_LLM_EXPERT_PROVIDER=
# KB_LLM_EXPERT_MODEL=

# ─── Ingestion ────────────────────────────────────────
# GitHub Personal Access Token. Without it, the GitHub Search API is
# rate-limited to 10 req/min — too low for the daily pipeline.
# Accepted as KB_GITHUB_TOKEN or GITHUB_TOKEN.
# GITHUB_TOKEN=
KB_ARXIV_PER_CATEGORY=50

# Lookback window for the orchestrator (kb.ingestion.run).
# - INGEST_EMPTY_DB_DAYS: cold-start backfill when the DB has zero papers.
# - INGEST_GAP_MIN_DAYS:  same-day re-runs still look at the last N days
#                         (0 would return nothing from date-cutoff sources).
# - INGEST_GAP_MAX_DAYS:  caps the gap when the DB has been idle for a long
#                         time so we don't trigger a multi-month re-fetch
#                         that hits API rate limits.
KB_INGEST_EMPTY_DB_DAYS=30
KB_INGEST_GAP_MIN_DAYS=1
KB_INGEST_GAP_MAX_DAYS=30

# ─── Quality gate ─────────────────────────────────────
# After scoring, papers whose max(originality, impact) >= threshold are
# kept as is_processed=1 ("active") and indexed into ChromaDB / shown in
# default API listings & daily reports. Below the threshold are marked
# is_processed=2 ("low quality, hidden") — kept in SQLite to prevent
# re-ingestion/re-scoring, but excluded from default views unless the
# caller passes ?include_low_quality=true. Changing this does NOT
# retroactively re-bucket existing rows.
KB_QUALITY_SCORE_THRESHOLD=7.0

# ─── API limits ───────────────────────────────────────
KB_CHAT_QUERY_MAX_LEN=32000
KB_CHAT_TOP_K_MAX=50

# ─── Chat auth ────────────────────────────────────────
# Optional bearer token guarding POST /api/chat. If unset, the endpoint
# is open (good for local dev). If set, callers must send
# `Authorization: Bearer <token>` or get 401.
# KB_CHAT_TOKEN=replace-me-with-a-long-random-string
